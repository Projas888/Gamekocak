                <div class="flex flex-col">
                    <label class="text-sm text-cyan-400 mb-1 font-mono">NIK (10 DIGIT)</label>
                    <input type="text" id="input-nik" required pattern="[0-9]{10}" maxlength="10" minlength="10" class="bg-gray-800 border border-gray-600 rounded p-2 text-white focus:outline-none focus:border-cyan-400" placeholder="Contoh: 1234567890" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');">
                    <span class="text-xs text-red-400 mt-1 hidden" id="nik-error">NIK harus tepat 10 digit angka.</span>
                </div>

                <div class="text-xs text-gray-400 mt-2">
                    <b>Peraturan:</b><br>
                    1. Sebuah kartu situasi akan muncul di tengah layar.<br>
                    2. Drag kartu ke <b>KIRI (Hijau/Setoran)</b> atau <b>KANAN (Merah/Tarikan)</b>.<br>
                    3. Waktu Anda hanya <b>7 DETIK</b> per skenario!
                </div>

                <button type="submit" id="btn-start" class="btn-cyber py-3 px-6 rounded font-bold mt-4 text-lg w-full">
                    SAYA SIAP MEMULAI MISI
                </button>
            </form>

            <div class="text-center text-xs font-mono text-gray-500 mt-8">
                Education & Training Dept. © 2026
            </div>
        </section>

        <!-- SECTION 2: CORE GAMEPLAY -->
        <section id="sec-game" class="hidden flex flex-col h-[85vh] md:h-[600px] gap-4 w-full">
            
            <!-- Header Status -->
            <div class="cyber-panel p-3 flex justify-between items-center text-sm md:text-base font-mono">
                <div class="flex flex-col w-1/3">
                    <span class="text-gray-400">OPERATOR: <span id="ui-nama" class="text-cyan-400 uppercase"></span></span>
                    <span class="text-gray-400">SCORE: <span id="ui-score" class="text-white">0</span>/100</span>
                </div>
                
                <div class="w-1/3 flex flex-col items-center">
                    <span class="text-gray-400 mb-1 text-xs">PROGRESS <span id="ui-progress-text">0%</span></span>
                    <div class="w-full bg-gray-700 h-2 rounded overflow-hidden">
                        <div id="ui-progress-bar" class="bg-cyan-400 h-full w-0 transition-all"></div>
                    </div>
                </div>

                <div class="w-1/3 text-right">
                    <span class="text-gray-400">SALDO RELASI</span>
                    <div class="font-bold text-xl md:text-2xl" id="ui-saldo">Rp 0</div>
                </div>
            </div>

            <!-- Timer -->
            <div class="w-full flex flex-col items-center mt-2">
                <span class="text-xs font-mono text-gray-400 mb-1">TIME REMAINING: <span id="ui-time-num">7.0</span>s</span>
                <div class="timer-track w-3/4 max-w-md">
                    <div id="ui-timer-bar" class="timer-fill"></div>
                </div>
            </div>

            <!-- Play Area -->
            <div class="relative flex-1 flex flex-col justify-end pb-4 mt-4" id="play-area">
                
                <!-- The Card -->
                <div id="active-card" class="draggable-card absolute top-4 md:top-10 left-1/2 -translate-x-1/2 w-4/5 max-w-sm p-6 rounded-lg text-center flex flex-col justify-center min-h-[150px]">
                    <span id="card-level" class="text-xs font-mono mb-2 text-cyan-400">LEVEL 1: MUDH</span>
                    <p id="card-text" class="text-base md:text-lg text-white font-medium leading-relaxed">
                        Memuat Skenario...
                    </p>
                </div>

                <!-- Drop Zones -->
                <div class="flex justify-between gap-4 w-full h-32 md:h-40 mt-auto">
                    <div id="zone-setoran" class="drop-zone green w-1/2 rounded-lg flex flex-col gap-2">
                        <span class="text-3xl">📥</span>
                        <span class="font-bold text-green-400 uppercase tracking-widest text-sm md:text-base">+ SETORAN</span>
                        <span class="text-xs text-gray-400 font-mono hidden md:block">(Constructive)</span>
                    </div>
                    <div id="zone-tarikan" class="drop-zone red w-1/2 rounded-lg flex flex-col gap-2">
                        <span class="text-3xl">📤</span>
                        <span class="font-bold text-red-400 uppercase tracking-widest text-sm md:text-base">- TARIKAN</span>
                        <span class="text-xs text-gray-400 font-mono hidden md:block">(Destructive)</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECTION 3: POST-ACTION DEBRIEF -->
        <section id="sec-result" class="hidden cyber-panel p-4 md:p-8 flex flex-col gap-6">
            <div class="text-center border-b border-gray-700 pb-4">
                <h2 class="text-2xl md:text-4xl font-bold mb-2 neon-text-blue">MISSION DEBRIEF</h2>
                <p class="text-gray-400 font-mono">Buku Tabungan Emosi & Hasil Evaluasi P-A-S</p>
            </div>

            <div class="flex flex-wrap justify-between items-center bg-black/40 p-4 rounded border border-gray-700">
                <div>
                    <p class="text-sm text-gray-400 font-mono">NAMA: <span id="res-nama" class="text-white"></span></p>
                    <p class="text-sm text-gray-400 font-mono">NIK: <span id="res-nik" class="text-white"></span></p>
                </div>
                <div class="text-right">
                    <p class="text-sm text-gray-400 font-mono">AKURASI</p>
                    <p class="text-3xl font-bold" id="res-score">0%</p>
                </div>
            </div>

            <div id="res-reinforcement" class="text-center p-4 rounded font-bold text-lg border">
                <!-- Reinforcement text dynamically inserted -->
            </div>

            <div class="text-sm text-cyan-400 font-mono mt-2 border-b border-gray-700 pb-2">Rincian Keputusan:</div>
            
            <div id="res-details" class="flex flex-col gap-3 max-h-[40vh] overflow-y-auto pr-2">
                <!-- Items appended here by JS -->
            </div>

            <button onclick="location.reload()" class="btn-cyber py-3 rounded font-bold mt-4">
                RE-EVALUASI MISI (MAIN LAGI)
            </button>
        </section>

    </main>

<script>
/* =======================================================================
   1. DATA SCENARIOS (10 Questions: 5 Easy, 5 Hard)
======================================================================== */
const questions = [
    // --- LEVEL 1: MUDAH (Clear Cut) ---
    {
        id: 1, diff: "EASY", type: "tarikan",
        text: '"Siapa yang salah ketik laporan ini?! Ngaku sekarang!"',
        exp: "Fokus menyalahkan individu. Ini menciptakan budaya ketakutan, bukan Psychological Safety."
    },
    {
        id: 2, diff: "EASY", type: "setoran",
        text: '"Mari kita bedah prosesnya, di titik mana sistem ini gagal agar tidak terulang?"',
        exp: "Penerapan P-A-S (Assess). Fokus pada kelemahan sistem (bukan orang), membangun ruang aman untuk berinovasi."
    },
    {
        id: 3, diff: "EASY", type: "tarikan",
        text: 'Mengabaikan anggota tim yang terlihat bingung dan tertekan saat menggunakan aplikasi baru.',
        exp: "Pengabaian. Manajer dengan EQ tinggi (Goleman) harus peka membaca keresahan emosional timnya."
    },
    {
        id: 4, diff: "EASY", type: "setoran",
        text: '"Terima kasih sudah jujur melaporkan error operasional ini dengan cepat ke saya."',
        exp: "Apresiasi transparansi. Ini adalah 'Setoran' besar yang mendorong staf berani lapor (speak up)."
    },
    {
        id: 5, diff: "EASY", type: "tarikan",
        text: '"Kalau error lagi bulan depan, bonus kalian satu tim saya potong!"',
        exp: "Intimidasi. Ancaman membuat staf cenderung menyembunyikan kesalahan di masa depan."
    },
    // --- LEVEL 2: SULIT (Gray Area) ---
    {
        id: 6, diff: "HARD", type: "setoran",
        text: 'Menunda sesi evaluasi insiden karena Anda melihat tim masih sangat panik dan emosional pasca masalah besar.',
        exp: "P-A-S (Pause). Regulasi emosi. Menunggu suasana kondusif sebelum evaluasi agar masukan bisa diterima logika."
    },
    {
        id: 7, diff: "HARD", type: "tarikan",
        text: 'Memberikan "feedback konstruktif" namun disebarkan ke dalam WhatsApp Group yang berisi seluruh divisi.',
        exp: "Mempermalukan di ruang publik (meski niatnya baik) adalah 'Tarikan' fatal yang menghancurkan harga diri dan trust."
    },
    {
        id: 8, diff: "HARD", type: "setoran",
        text: 'Meminta staf yang terbukti melakukan kelalaian untuk memimpin tim kecil merumuskan perbaikan SOP.',
        exp: "Support/Pemberdayaan. Membangun kembali kepercayaan diri staf pasca kegagalan."
    },
    {
        id: 9, diff: "HARD", type: "tarikan",
        text: 'Langsung mengambil alih paksa pekerjaan staf saat melihatnya kesulitan tanpa bertanya/diskusi dulu.',
        exp: "Micromanagement. Meski pekerjaan cepat selesai, relasi rusak karena staf merasa tidak dipercaya."
    },
    {
        id: 10, diff: "HARD", type: "setoran",
        text: 'Menegur staf secara tertutup, murni mengkritisi perilakunya, tanpa menyerang karakter personalnya.',
        exp: "Constructive feedback yang aman secara psikologis. Menunjukkan respect meskipun sedang mengoreksi."
    }
];

/* =======================================================================
   2. GAME STATE & VARIABLES
======================================================================== */
let currentQIndex = 0;
let score = 0;
let saldo = 0;
let timer;
let timeLeft = 7.0;
const TIME_LIMIT = 7.0;
let isDragging = false;
let userAnswers = []; // Store { q: Object, answered: string, correct: boolean }
let gameActive = false;

// DOM Elements
const elGateway = document.getElementById('sec-gateway');
const elGame = document.getElementById('sec-game');
const elResult = document.getElementById('sec-result');
const card = document.getElementById('active-card');
const zoneSetoran = document.getElementById('zone-setoran');
const zoneTarikan = document.getElementById('zone-tarikan');
const btnMute = document.getElementById('btn-mute');

// Drag State
let startX = 0, startY = 0, currentX = 0, currentY = 0;
let initialCardLeft, initialCardTop;

/* =======================================================================
   3. AUDIO SYNTHESIZER ENGINE (Web Audio API)
======================================================================== */
let audioCtx;
let masterGain;
let isMuted = false;
let bgmOsc = null;
let bgmInterval;

const NOTES = {
    C2: 65.41, D2: 73.42, E2: 82.41, G2: 98.00, A2: 110.00,
    C4: 261.63, E4: 329.63, G4: 392.00, C5: 523.25, D5: 587.33
};

function initAudio() {
    if(audioCtx) return; // already init
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    masterGain = audioCtx.createGain();
    // Prompt volume request "2.5". Setting master gain to 2.5 relative to synth volumes.
    masterGain.gain.value = 2.5; 
    masterGain.connect(audioCtx.destination);
}

function playTone(freq, type, duration, vol = 0.1) {
    if(!audioCtx || isMuted) return;
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    
    osc.type = type;
    osc.frequency.value = freq;
    
    osc.connect(gain);
    gain.connect(masterGain);
    
    // Envelope
    gain.gain.setValueAtTime(0, audioCtx.currentTime);
    gain.gain.linearRampToValueAtTime(vol, audioCtx.currentTime + 0.05);
    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + duration);
    
    osc.start(audioCtx.currentTime);
    osc.stop(audioCtx.currentTime + duration);
}

// BGM Engine
const bgmSequence = [NOTES.C2, NOTES.G2, NOTES.C2, NOTES.A2];
let bgmStep = 0;
function startBGM() {
    if(bgmInterval) clearInterval(bgmInterval);
    bgmInterval = setInterval(() => {
        // Hapus syarat 'gameActive' agar BGM menyala di halaman awal
        if(!isMuted) { 
            playTone(bgmSequence[bgmStep % 4], 'square', 0.2, 0.05);
            bgmStep++;
        }
    }, 400); // 150 BPM
}
function stopBGM() { clearInterval(bgmInterval); }

function toggleMute() {
    isMuted = !isMuted;
    btnMute.innerText = isMuted ? "🔇 BGM: OFF" : "🔊 BGM: ON";
    if(!isMuted && audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
}

let audioUnlocked = false;
function unlockAudio() {
    if(audioUnlocked) return;
    initAudio();
    if(audioCtx && audioCtx.state === 'suspended') {
        audioCtx.resume();
    }
    startBGM();
    audioUnlocked = true;
    
    // Hapus event listener setelah audio berhasil dipicu
    document.removeEventListener('click', unlockAudio);
    document.removeEventListener('touchstart', unlockAudio);
    document.removeEventListener('keydown', unlockAudio);
}

// Memicu audio menyala otomatis pada interaksi (klik/ketik) PERTAMA di halaman awal
document.addEventListener('click', unlockAudio);
document.addEventListener('touchstart', unlockAudio);
document.addEventListener('keydown', unlockAudio);

// SFX
function sfxCorrect() {
    playTone(NOTES.C4, 'sine', 0.1, 0.1);
    setTimeout(() => playTone(NOTES.E4, 'sine', 0.1, 0.1), 100);
    setTimeout(() => playTone(NOTES.G4, 'sine', 0.2, 0.1), 200);
}
function sfxWrong() {
    playTone(NOTES.D2, 'sawtooth', 0.4, 0.15);
}
function sfxTick() {
    playTone(NOTES.C5, 'square', 0.05, 0.02);
}
function sfxBadge() {
    playTone(NOTES.C4, 'square', 0.1, 0.1);
    setTimeout(() => playTone(NOTES.G4, 'square', 0.1, 0.1), 100);
    setTimeout(() => playTone(NOTES.C5, 'square', 0.3, 0.1), 200);
}

/* =======================================================================
   4. GAME LOGIC & FLOW
======================================================================== */

function showToast(msg) {
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = 'toast show';
    toast.innerHTML = `🏆 <b>BADGE UNLOCKED!</b><br>${msg}`;
    container.appendChild(toast);
    sfxBadge();
    setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => toast.remove(), 500);
    }, 3000);
}

function startGame(e) {
    e.preventDefault();
    const nik = document.getElementById('input-nik').value;
    if(nik.length !== 10) {
        document.getElementById('nik-error').classList.remove('hidden');
        return;
    }
    
    // UI Transitions
    elGateway.classList.add('hidden');
    elGame.classList.remove('hidden');
    
    document.getElementById('ui-nama').innerText = document.getElementById('input-nama').value;
    
    gameActive = true;
    
    // Reset State
    currentQIndex = 0;
    score = 0;
    saldo = 50000; // Starting virtual bank
    userAnswers = [];
    updateUIStatus();
    
    loadQuestion();
}

function updateUIStatus() {
    document.getElementById('ui-score').innerText = score * 10; // Max 100
    document.getElementById('ui-saldo').innerText = `Rp ${saldo.toLocaleString('id-ID')}`;
    
    const progress = (currentQIndex / questions.length) * 100;
    document.getElementById('ui-progress-bar').style.width = `${progress}%`;
    document.getElementById('ui-progress-text').innerText = `${Math.floor(progress)}%`;
    
    if(saldo < 0) {
        document.getElementById('ui-saldo').classList.remove('text-white', 'text-green-400');
        document.getElementById('ui-saldo').classList.add('text-red-400');
    } else {
        document.getElementById('ui-saldo').classList.remove('text-white', 'text-red-400');
        document.getElementById('ui-saldo').classList.add('text-green-400');
    }
}

function loadQuestion() {
    if(currentQIndex >= questions.length) {
        endGame();
        return;
    }

    // Badge triggers
    if(currentQIndex === 5) showToast("Junior Manager (Selesai Level Mudah)");

    const q = questions[currentQIndex];
    document.getElementById('card-text').innerText = `"${q.text}"`;
    document.getElementById('card-level').innerText = `LEVEL ${q.diff === 'EASY' ? '1: MUDAH' : '2: SULIT'}`;
    
    // Reset Card position
    card.style.transform = `translate(-50%, 0)`;
    card.style.left = '50%';
    card.style.top = '20px'; // relative to play-area
    
    // Reset Drag state refs
    currentX = 0; currentY = 0;
    
    // Reset Timer
    timeLeft = TIME_LIMIT;
    document.getElementById('ui-timer-bar').classList.remove('timer-warning');
    updateTimerUI();
    
    clearInterval(timer);
    timer = setInterval(tickTimer, 100);
}

function tickTimer() {
    if(!gameActive) return;
    timeLeft -= 0.1;
    updateTimerUI();

    if(timeLeft <= 3.0 && timeLeft > 2.8 || timeLeft <= 2.0 && timeLeft > 1.8 || timeLeft <= 1.0 && timeLeft > 0.8) {
        sfxTick();
        document.getElementById('ui-timer-bar').classList.add('timer-warning');
    }

    if(timeLeft <= 0) {
        clearInterval(timer);
        handleAnswer('timeout'); // Out of time counts as wrong automatically based on rule
    }
}

function updateTimerUI() {
    const pct = Math.max(0, (timeLeft / TIME_LIMIT) * 100);
    document.getElementById('ui-timer-bar').style.width = `${pct}%`;
    document.getElementById('ui-time-num').innerText = Math.max(0, timeLeft).toFixed(1);
}

function handleAnswer(userChoice) {
    clearInterval(timer);
    const q = questions[currentQIndex];
    const isCorrect = userChoice === q.type;

    // Save history
    userAnswers.push({
        question: q.text,
        type: q.type,
        userAns: userChoice,
        correct: isCorrect,
        explanation: q.exp
    });

    // Feedback
    if(isCorrect) {
        sfxCorrect();
        score++;
        saldo += 15000; // Deposit
        document.body.classList.add('flash-success');
        setTimeout(()=> document.body.classList.remove('flash-success'), 500);
    } else {
        sfxWrong();
        saldo -= 25000; // Heavy penalty for withdrawal
        document.body.classList.add('flash-danger', 'screen-shake');
        setTimeout(()=> document.body.classList.remove('flash-danger', 'screen-shake'), 400);
    }

    updateUIStatus();

    // Hide card momentarily
    card.style.opacity = 0;
    
    setTimeout(() => {
        card.style.opacity = 1;
        currentQIndex++;
        loadQuestion();
    }, 600);
}

function endGame() {
    gameActive = false;
    stopBGM();
    showToast("Master of Empathy (Semua Level Selesai)");
    setTimeout(() => {
        elGame.classList.add('hidden');
        elResult.classList.remove('hidden');
        renderDebrief();
    }, 1500);
}

/* =======================================================================
   5. DEBRIEF & RESULT RENDER
======================================================================== */
function renderDebrief() {
    document.getElementById('res-nama').innerText = document.getElementById('input-nama').value;
    document.getElementById('res-nik').innerText = document.getElementById('input-nik').value;
    
    const finalScore = score * 10;
    document.getElementById('res-score').innerText = `${finalScore}%`;
    
    const reinf = document.getElementById('res-reinforcement');
    if(finalScore >= 80) {
        reinf.className = "text-center p-4 rounded font-bold text-lg border border-green-500 bg-green-900/30 text-green-400";
        reinf.innerHTML = `Luar Biasa! Anda adalah <i>Trust Builder</i> sejati. Tim merasa aman dan produktif di bawah arahan Anda.`;
    } else if (finalScore >= 50) {
        reinf.className = "text-center p-4 rounded font-bold text-lg border border-yellow-500 bg-yellow-900/30 text-yellow-400";
        reinf.innerHTML = `Cukup Baik, namun Bank Emosi Anda berisiko ditarik habis. Ingat selalu metode P-A-S sebelum merespons kegagalan.`;
    } else {
        reinf.className = "text-center p-4 rounded font-bold text-lg border border-red-500 bg-red-900/30 text-red-400";
        reinf.innerHTML = `Waspada! Gaya komunikasi Anda saat ini memicu kebangkrutan emosional tim. Tim akan takut berinovasi. Evaluasi kembali materi P-A-S.`;
    }

    const detailsBox = document.getElementById('res-details');
    detailsBox.innerHTML = '';

    userAnswers.forEach((ans, i) => {
        const isRight = ans.correct;
        const colorBorder = isRight ? 'border-green-600' : 'border-red-600';
        const colorBg = isRight ? 'bg-green-900/20' : 'bg-red-900/20';
        const icon = isRight ? '✅' : '❌';
        const userAction = ans.userAns === 'timeout' ? 'HABIS WAKTU' : ans.userAns.toUpperCase();

        const item = `
            <div class="border-l-4 ${colorBorder} ${colorBg} p-3 rounded">
                <p class="text-xs text-gray-400 mb-1">SKENARIO ${i+1}</p>
                <p class="text-sm font-medium text-white mb-2">"${ans.question}"</p>
                <div class="flex justify-between items-center text-xs font-mono mb-2">
                    <span>Jawaban Anda: <b class="${isRight ? 'text-green-400' : 'text-red-400'}">${userAction}</b> ${icon}</span>
                    <span class="text-cyan-400">Seharusnya: ${ans.type.toUpperCase()}</span>
                </div>
                <p class="text-xs text-gray-400 bg-black/40 p-2 rounded"><b>Analisis:</b> ${ans.explanation}</p>
            </div>
        `;
        detailsBox.innerHTML += item;
    });
}

/* =======================================================================
   6. DRAG & DROP MECHANICS (Mouse & Touch)
======================================================================== */

function getEventPos(e) {
    if(e.type.includes('mouse')) {
        return { x: e.clientX, y: e.clientY };
    } else {
        return { x: e.touches[0].clientX, y: e.touches[0].clientY };
    }
}

function startDrag(e) {
    if(!gameActive) return;
    isDragging = true;
    const pos = getEventPos(e);
    
    // To handle translate(-50%, 0), we just track delta
    startX = pos.x;
    startY = pos.y;
    
    card.style.transition = 'none';
}

function onDrag(e) {
    if(!isDragging || !gameActive) return;
    e.preventDefault(); // Prevent scroll on mobile
    
    const pos = getEventPos(e);
    const dx = pos.x - startX;
    const dy = pos.y - startY;
    
    // Apply delta to existing transform logic (-50% X base)
    card.style.transform = `translate(calc(-50% + ${dx}px), ${dy}px)`;
    
    // Check overlap for visual feedback
    const cardRect = card.getBoundingClientRect();
    const zoneS = zoneSetoran.getBoundingClientRect();
    const zoneT = zoneTarikan.getBoundingClientRect();
    
    // Reset visual
    zoneSetoran.classList.remove('active-drag');
    zoneTarikan.classList.remove('active-drag');
    
    const threshold = 30; // overlap threshold
    
    if (intersect(cardRect, zoneS, threshold)) {
        zoneSetoran.classList.add('active-drag');
    } else if (intersect(cardRect, zoneT, threshold)) {
        zoneTarikan.classList.add('active-drag');
    }
}

function endDrag(e) {
    if(!isDragging) return;
    isDragging = false;
    card.style.transition = 'transform 0.3s ease';
    
    const cardRect = card.getBoundingClientRect();
    const zoneS = zoneSetoran.getBoundingClientRect();
    const zoneT = zoneTarikan.getBoundingClientRect();
    
    zoneSetoran.classList.remove('active-drag');
    zoneTarikan.classList.remove('active-drag');
    
    const threshold = 30;
    
    if (intersect(cardRect, zoneS, threshold)) {
        handleAnswer('setoran');
    } else if (intersect(cardRect, zoneT, threshold)) {
        handleAnswer('tarikan');
    } else {
        // Snap back if dropped outside
        card.style.transform = `translate(-50%, 0)`;
    }
}

// Simple AABB collision detection with threshold
function intersect(r1, r2, threshold) {
    return !(
        r2.left > r1.right - threshold || 
        r2.right < r1.left + threshold || 
        r2.top > r1.bottom - threshold ||
        r2.bottom < r1.top + threshold
    );
}

// Attach listeners
card.addEventListener('mousedown', startDrag);
window.addEventListener('mousemove', onDrag);
window.addEventListener('mouseup', endDrag);

card.addEventListener('touchstart', startDrag, {passive: false});
window.addEventListener('touchmove', onDrag, {passive: false});
window.addEventListener('touchend', endDrag);

</script>
